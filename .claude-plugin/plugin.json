{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "phovia",
  "displayName": "Phovia",
  "version": "0.1.4",
  "description": "Phovia memory hooks and local MCP search for Claude Code, with device login.",
  "author": {
    "name": "PhoviaAI"
  },
  "repository": "https://github.com/PhoviaAI/phovia-plugin",
  "homepage": "https://github.com/PhoviaAI/phovia-plugin#readme",
  "keywords": [
    "phovia",
    "memory",
    "mcp",
    "hooks",
    "device-auth",
    "claude-code"
  ],
  "userConfig": {
    "brain_url": {
      "type": "string",
      "title": "Phovia Brain URL (advanced \u2014 leave as default)",
      "description": "Optional. API base URL of the Phovia brain. Defaults to the hosted Phovia service; only change this if you self-host.",
      "default": "https://api.phovia.ai/api",
      "required": false
    }
  },
  "mcpServers": {
    "phovia-memory": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/server.mjs"
      ],
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules",
        "PHOVIA_MCP_DEPS_DIR": "${CLAUDE_PLUGIN_DATA}"
      }
    }
  }
}
