{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/mcp/install-deps.mjs"
            ],
            "timeout": 120,
            "statusMessage": "Preparing Phovia MCP dependencies"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/phovia",
              "hook",
              "session-start"
            ],
            "timeout": 10,
            "statusMessage": "Recalling Phovia memory"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/phovia",
              "hook",
              "stop"
            ],
            "timeout": 30,
            "statusMessage": "Syncing Phovia memory"
          }
        ]
      }
    ]
  }
}
